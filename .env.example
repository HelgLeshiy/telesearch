# ---------------------------------------------------------------------------
# telesearch configuration. Copy to ".env" and adjust to your setup.
# All values are optional; sensible defaults are used when unset.
# ---------------------------------------------------------------------------

# Where the LanceDB index and extracted artifacts live.
TELESEARCH_DATA_DIR=./data

# ----- Embedding models (run locally on the GPU) ---------------------------
# Text embeddings (multilingual, strong retrieval quality).
TELESEARCH_TEXT_EMBED_MODEL=BAAI/bge-m3
# Multimodal (image<->text) embeddings for visual similarity search.
TELESEARCH_IMAGE_EMBED_MODEL=jinaai/jina-clip-v2
# Torch device for local models.
TELESEARCH_DEVICE=cuda

# ----- Vision-language + chat model (served via an OpenAI-compatible API) ---
# Point this at a local vLLM / SGLang / Ollama server.
#   vLLM example:
#     vllm serve Qwen/Qwen2.5-VL-32B-Instruct --port 8000 --served-model-name qwen-vl
TELESEARCH_LLM_BASE_URL=http://localhost:8000/v1
TELESEARCH_LLM_API_KEY=EMPTY
# Vision-language model used to caption images and video frames.
TELESEARCH_VLM_MODEL=Qwen/Qwen2.5-VL-32B-Instruct
# Text chat model used for RAG answers (can be the same VLM endpoint).
TELESEARCH_CHAT_MODEL=Qwen/Qwen2.5-VL-32B-Instruct

# ----- Audio transcription -------------------------------------------------
TELESEARCH_WHISPER_MODEL=large-v3
# Whisper compute type: float16 (GPU), int8_float16, or int8 (CPU).
TELESEARCH_WHISPER_COMPUTE=float16
# Sample this many evenly spaced frames per video for captioning.
TELESEARCH_VIDEO_FRAMES=4
