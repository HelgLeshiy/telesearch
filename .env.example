# ---------------------------------------------------------------------------
# telesearch configuration. Copy to ".env" and adjust to your setup.
# All values are optional; sensible defaults are used when unset.
# ---------------------------------------------------------------------------

# Where the LanceDB index and extracted artifacts live.
TELESEARCH_DATA_DIR=./data

# ----- Embedding models (run locally on the GPU) ---------------------------
# Text embeddings (multilingual, strong retrieval quality).
TELESEARCH_TEXT_EMBED_MODEL=BAAI/bge-m3
# Multimodal (image<->text) embeddings for visual similarity search.
TELESEARCH_IMAGE_EMBED_MODEL=jinaai/jina-clip-v2
# Torch device for local models.
TELESEARCH_DEVICE=cuda
# Texts embedded per GPU forward pass. Lower this if you hit CUDA out-of-memory
# during indexing (e.g. when the embedder shares a GPU with the vLLM server).
TELESEARCH_EMBED_BATCH_SIZE=64
# Max embedding input length in tokens. bge-m3 allows 8192, but long texts then
# create multi-GiB activations and can OOM the GPU. Chat chunks are short, so
# 512 keeps memory bounded; raise it if you index long documents and have VRAM.
TELESEARCH_EMBED_MAX_SEQ_LENGTH=512

# ----- Reranker (cross-encoder, sharpens precision of top results) ---------
TELESEARCH_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
TELESEARCH_USE_RERANKER=true
# How many hybrid candidates to fetch before reranking down to the top-k.
TELESEARCH_RERANK_CANDIDATES=50

# ----- Conversation context ------------------------------------------------
# Telegram messages are short and fragmented; embedding each one alone loses
# context and rarely matches a full question. Also index overlapping *windows*
# of consecutive messages so retrieval sees the surrounding conversation.
TELESEARCH_ENABLE_CONVERSATION_WINDOWS=true
TELESEARCH_CONVERSATION_WINDOW_SIZE=6      # messages grouped per window
TELESEARCH_CONVERSATION_WINDOW_STRIDE=3    # advance between windows (overlap = size - stride)
# Don't span a window across a silence larger than this (seconds).
TELESEARCH_CONVERSATION_WINDOW_MAX_GAP=3600

# ----- Answering (`ask` / RAG) ---------------------------------------------
# Pull this many messages of surrounding context on each side of every hit so
# the model can answer from the conversation, not a single matched line. 0 off.
TELESEARCH_CONTEXT_NEIGHBORS=4
# HyDE: draft a hypothetical answer and retrieve with it too, bridging the gap
# between a question and the casual message that answers it (better recall).
TELESEARCH_ENABLE_HYDE=true

# ----- OCR (verbatim on-image text as its own searchable chunk) ------------
TELESEARCH_ENABLE_OCR=true

# ----- Document attachments (PDF, Office, text/code/CSV, ...) ---------------
TELESEARCH_ENABLE_DOCUMENTS=true
# Long documents are split into overlapping chunks for better retrieval.
TELESEARCH_DOC_CHUNK_CHARS=1200
TELESEARCH_DOC_CHUNK_OVERLAP=150
# Cap text extracted per document (protects against huge files).
TELESEARCH_DOC_MAX_CHARS=400000

# ----- Vision-language + chat model (served via an OpenAI-compatible API) ---
# Point this at a local vLLM / SGLang / Ollama server.
#   vLLM example:
#     vllm serve Qwen/Qwen2.5-VL-32B-Instruct --port 8000 --served-model-name qwen-vl
TELESEARCH_LLM_BASE_URL=http://localhost:8000/v1
TELESEARCH_LLM_API_KEY=EMPTY
# Vision-language model used to caption images and video frames.
TELESEARCH_VLM_MODEL=Qwen/Qwen2.5-VL-32B-Instruct
# Text chat model used for RAG answers (can be the same VLM endpoint).
TELESEARCH_CHAT_MODEL=Qwen/Qwen2.5-VL-32B-Instruct
# Per-request timeout (seconds) and retries for VLM/chat calls. Without a
# timeout the client waits ~10 min per request, so one stuck call freezes the
# whole indexing block. Lower for faster failover; raise for very large images.
TELESEARCH_LLM_REQUEST_TIMEOUT=120
TELESEARCH_LLM_MAX_RETRIES=2

# ----- Audio transcription -------------------------------------------------
TELESEARCH_WHISPER_MODEL=large-v3
# Whisper compute type: float16 (GPU), int8_float16, or int8 (CPU).
TELESEARCH_WHISPER_COMPUTE=float16
# Sample this many evenly spaced frames per video for captioning.
TELESEARCH_VIDEO_FRAMES=4
# Concurrent in-flight VLM caption/OCR requests during indexing (throughput).
TELESEARCH_MEDIA_WORKERS=8
# Wall-clock budget (seconds) per message during indexing. A message exceeding
# it (e.g. a corrupt image whose decode hangs, or a very slow document/audio)
# is logged and skipped instead of stalling the whole run. 0 disables the guard.
TELESEARCH_MEDIA_ITEM_TIMEOUT=180
# If no message completes for this many seconds, dump the in-flight messages and
# every thread's stack to stderr so a hang is immediately diagnosable (it names
# the stuck file and the exact call). 0 disables the watchdog.
TELESEARCH_HANG_TRACEBACK_SECONDS=60
# Largest image (megapixels) decoded for captioning/OCR. Bigger photos are
# downscaled by the JPEG decoder first; this also blocks decompression bombs
# that can hang a worker or exhaust memory.
TELESEARCH_MAX_IMAGE_MEGAPIXELS=50

# ----- Docker Compose -------------------------------------------------------
# Absolute path to your Telegram export folder (mounted read-only as /export).
TELESEARCH_EXPORT_ROOT=/path/to/telegram_export
# Host ports when running `docker compose up`.
TELESEARCH_VLLM_HOST_PORT=8000
TELESEARCH_UI_HOST_PORT=8501

# ----- vLLM server memory tuning (docker compose `vllm` service) -----------
# Context window vLLM reserves KV cache for. The model supports 128k, but that
# alone needs ~31 GiB of KV cache on top of the weights and overflows the GPU.
# telesearch only sends a few images plus a short prompt (<=256 output tokens),
# so a smaller window is plenty. Raise this if you have spare VRAM.
TELESEARCH_VLLM_MAX_MODEL_LEN=32768
# Fraction of GPU memory vLLM may use (weights + KV cache + activations).
# Kept below 1.0 so telesearch's own GPU models (embeddings + Whisper), which
# share the same GPU, have room. Raise toward 0.92 only if vLLM has its own GPU.
TELESEARCH_VLLM_GPU_MEMORY_UTILIZATION=0.80
# Max multimodal items per request. Video frames are sent as images, so we
# allow several images and disable native-video profiling (which wastes VRAM).
TELESEARCH_VLLM_LIMIT_MM_PER_PROMPT={"image": 8, "video": 0}
# Hugging Face token (only needed for gated models).
# HUGGING_FACE_HUB_TOKEN=
